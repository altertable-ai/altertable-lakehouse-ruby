module Altertable
  module Lakehouse
    class Client
      @auth_header: String
      @base_url: String
      @timeout: Integer | Float
      @user_agent: String
      @adapter: untyped

      DEFAULT_BASE_URL: String
      DEFAULT_TIMEOUT: Integer

      def initialize: (
        ?username: String?,
        ?password: String?,
        ?basic_auth_token: String?,
        ?base_url: String?,
        ?timeout: Integer | Float?,
        ?user_agent: String?,
        ?adapter: Symbol?,
        ?headers: ::Hash[String, String]
      ) -> void

      def append: (
        catalog: String,
        schema: String,
        table: String,
        payload: ::Hash[untyped, untyped] | ::Array[::Hash[untyped, untyped]],
        ?sync: bool?,
        ?headers: ::Hash[String, String]
      ) -> Models::AppendResponse

      def get_task: (String task_id, ?headers: ::Hash[String, String]) -> Models::TaskResponse

      def query: (statement: String, ?headers: ::Hash[String, String], **untyped options) -> QueryResult

      def query_all: (statement: String, ?headers: ::Hash[String, String], **untyped options) -> ::Hash[Symbol, untyped]

      def upsert: (
        catalog: String,
        schema: String,
        table: String,
        file_io: untyped,
        ?mode: String?,
        ?primary_key: String?,
        ?headers: ::Hash[String, String]
      ) -> untyped

      def get_query: (String query_id, ?headers: ::Hash[String, String]) -> Models::QueryLogResponse

      def cancel_query: (String query_id, session_id: String, ?headers: ::Hash[String, String]) -> Models::CancelQueryResponse

      def validate: (
        statement: String,
        ?catalog: String?,
        ?schema: String?,
        ?session_id: String?,
        ?headers: ::Hash[String, String]
      ) -> Models::ValidateResponse

      def autocomplete: (
        statement: String,
        ?catalog: String?,
        ?schema: String?,
        ?session_id: String?,
        ?max_suggestions: Integer?,
        ?headers: ::Hash[String, String]
      ) -> Models::AutocompleteResponse

      def explain: (
        statement: String,
        ?catalog: String?,
        ?schema: String?,
        ?session_id: String?,
        ?include_plan: bool?,
        ?headers: ::Hash[String, String]
      ) -> Models::ExplainResponse

      private

      def select_adapter: (Symbol? name, untyped options) -> untyped
      def try_require: (String gem_name) -> bool
      def request: (
        Symbol method,
        String path,
        ?body: untyped,
        ?query: ::Hash[Symbol | String, untyped]?,
        ?headers: ::Hash[String, String]
      ) -> untyped
      def handle_stream_response: (Adapters::Response resp, String buffer, Enumerator::Yielder yielder) -> void
      def handle_response: (Adapters::Response resp) -> untyped
    end

    class QueryResult
      include Enumerable

      @enum: Enumerator[untyped, untyped]
      @metadata: untyped
      @columns: untyped

      attr_reader metadata: untyped
      attr_reader columns: untyped

      def initialize: (Enumerator[untyped, untyped] enum) -> void
      def each: () { (untyped) -> void } -> void
    end
  end
end
